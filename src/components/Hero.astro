---
import GlowEffect from './GlowEffect.astro';
import Tachometer from './Tachometer.astro';
import HeroStats from './HeroStats.astro';
import Icons from './Icons.astro';
import type { Language } from '@/i18n/config';
import { t } from '@/i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden px-6" id="hero">
  <GlowEffect class="left-1/2 top-1/3 -translate-x-1/2 -translate-y-1/2" size="400px" />

  <div class="relative z-10 text-center">
    <p data-animate class="text-sm tracking-widest text-text-muted uppercase md:text-base" id="hero-greeting">
      {t(lang, 'hero.role')}
    </p>

    <div class="mt-6 mb-6" id="hero-tachometer" data-animate>
      <Tachometer />
    </div>

    <p data-animate class="mx-auto max-w-lg text-base text-text-secondary md:text-lg" id="hero-tagline">
      {t(lang, 'hero.tagline')}
    </p>

    <div data-animate class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row" id="hero-cta">
      <a
        href="#projects"
        class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-primary to-primary-light px-6 py-3 font-medium text-white transition-all hover:shadow-lg hover:shadow-primary/25"
      >
        {t(lang, 'hero.cta.projects')}
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-xl border border-border px-6 py-3 font-medium text-text transition-all hover:border-text-muted hover:bg-surface"
      >
        {t(lang, 'hero.cta.contact')}
      </a>
    </div>

    <HeroStats lang={lang} />
  </div>

  <!-- Scroll indicator -->
  <div data-animate class="absolute bottom-8 left-1/2 -translate-x-1/2" id="scroll-indicator">
    <a href="#projects" aria-label="Scroll to projects" class="text-text-muted transition-colors hover:text-text">
      <Icons name="arrow-down" size={24} />
    </a>
  </div>
</section>
