---
---

<div class="tachometer-container mx-auto w-full max-w-[280px] md:max-w-[340px]">
  <svg class="tachometer-svg w-full h-auto" id="tachometer" viewBox="0 0 400 310" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Tachometer animation">
    <defs>
      <linearGradient id="needleGrad" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#E31E24" />
        <stop offset="60%" stop-color="#B01018" />
        <stop offset="100%" stop-color="#6B0A0E" />
      </linearGradient>
      <radialGradient id="capGrad" cx="50%" cy="40%" r="50%">
        <stop offset="0%" stop-color="#444" />
        <stop offset="100%" stop-color="#111" />
      </radialGradient>
      <filter id="redGlow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <!-- Bezel -->
    <circle cx="200" cy="200" r="190" fill="#0F0F11" stroke="#1E1E22" stroke-width="2" />
    <circle cx="200" cy="200" r="185" fill="none" stroke="#161618" stroke-width="1" />

    <!-- Generated by JS -->
    <g id="tickMarks"></g>
    <g id="numberLabels"></g>
    <g id="redZoneArc"></g>
    <g id="outerArc"></g>

    <!-- Needle -->
    <g id="needleGroup">
      <polygon id="needleShadow" points="200,55 195,200 205,200" fill="rgba(0,0,0,0.4)" filter="url(#redGlow)" opacity="0" />
      <polygon id="needle" points="200,60 196.5,195 203.5,195" fill="url(#needleGrad)" />
      <line id="needleTip" x1="200" y1="60" x2="200" y2="100" stroke="#E31E24" stroke-width="1.5" stroke-linecap="round" opacity="0.8" />
    </g>

    <!-- Center cap -->
    <circle cx="200" cy="200" r="14" fill="url(#capGrad)" stroke="#333" stroke-width="1" />
    <circle cx="200" cy="200" r="5" fill="#F5C518" opacity="0.9" />

    <!-- RPM display -->
    <text id="rpmText" x="200" y="260" text-anchor="middle" fill="#CCCCCC" font-family="'JetBrains Mono', monospace" font-size="28" font-weight="700" letter-spacing="1">0</text>
    <text x="200" y="278" text-anchor="middle" fill="#666666" font-family="'JetBrains Mono', monospace" font-size="8" letter-spacing="3">RPM x1000</text>
  </svg>
</div>

<style>
  .tachometer-svg {
    filter: drop-shadow(0 0 40px rgba(227, 30, 36, 0.15));
    transition: filter 0.3s;
  }
  .tachometer-svg.redzone-active {
    filter: drop-shadow(0 0 60px rgba(227, 30, 36, 0.35));
  }
</style>
