---
import GlowEffect from './GlowEffect.astro';
import Icons from './Icons.astro';
import type { Language } from '@/i18n/config';
import { t } from '@/i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section class="relative overflow-hidden px-6 py-24 md:py-32" id="contact">
  <GlowEffect class="left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2" size="500px" />

  <div data-animate class="relative z-10 mx-auto max-w-2xl text-center">
    <h2 class="font-heading text-3xl font-bold tracking-tight md:text-5xl">
      {t(lang, 'contact.title')}<span class="text-primary">.</span>
    </h2>
    <p class="mt-4 text-base text-text-secondary md:text-lg">
      {t(lang, 'contact.subtitle')}
    </p>

    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="https://t.me/temrjan"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 rounded-xl bg-gradient-to-r from-primary to-primary-light px-6 py-3 font-medium text-white transition-all hover:shadow-lg hover:shadow-primary/25"
      >
        <Icons name="telegram" size={20} />
        {t(lang, 'contact.telegram')}
      </a>
      <a
        href="mailto:x.temrjan@gmail.com"
        class="inline-flex items-center gap-3 rounded-xl border border-border px-6 py-3 font-medium text-text transition-all hover:border-text-muted hover:bg-surface"
      >
        <Icons name="email" size={20} />
        {t(lang, 'contact.email')}
      </a>
    </div>
  </div>
</section>
