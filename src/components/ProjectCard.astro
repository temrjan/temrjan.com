---
import TechBadge from './TechBadge.astro';
import Icons from './Icons.astro';
import type { Language } from '@/i18n/config';
import type { Project } from '@/data/projects';
import { t } from '@/i18n/utils';

interface Props {
  project: Project;
  lang: Language;
}

const { project, lang } = Astro.props;
const Tag = project.url ? 'a' : 'div';
const linkProps = project.url ? { href: project.url, target: '_blank', rel: 'noopener noreferrer' } : {};
---

<Tag
  {...linkProps}
  data-animate
  class:list={[
    'project-card group relative block overflow-hidden rounded-2xl border border-border bg-surface transition-all duration-300 hover:-translate-y-2 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/5',
    project.span === 2 ? 'md:col-span-2' : '',
    project.url ? 'cursor-pointer' : '',
  ]}
>
  <!-- Project image -->
  <div class="relative aspect-video overflow-hidden bg-elevated">
    <div
      class="absolute inset-0"
      style={`background: linear-gradient(135deg, var(--color-elevated) 0%, var(--color-surface) 50%, var(--color-primary-glow) 100%);`}
    />
    <div class="absolute inset-0 flex items-center justify-center">
      <span class="font-heading text-2xl font-bold text-text-muted/30">{project.title}</span>
    </div>
    {project.url && (
      <div class="absolute right-3 top-3 flex h-8 w-8 items-center justify-center rounded-lg bg-body/60 text-text-muted backdrop-blur-sm transition-all group-hover:text-text">
        <Icons name="external-link" size={16} />
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-5">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-heading text-lg font-semibold text-text">{project.title}</h3>
      <span class="shrink-0 font-mono text-sm font-bold text-accent">
        {project.loc} {t(lang, 'projects.loc')}
      </span>
    </div>

    <p class="mt-2 line-clamp-2 text-sm text-text-secondary">
      {project.descriptions[lang]}
    </p>

    <div class="mt-4 flex flex-wrap gap-2">
      {project.tech.map((techName) => (
        <TechBadge name={techName} />
      ))}
    </div>
  </div>
</Tag>
