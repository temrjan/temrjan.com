---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div data-animate class="mb-12 text-center md:mb-16">
  <h2 class="font-heading text-3xl font-bold tracking-tight md:text-5xl">
    {title}<span class="text-primary">.</span>
  </h2>
  {subtitle && (
    <p class="mt-3 text-base text-text-secondary md:text-lg">{subtitle}</p>
  )}
</div>
