---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SUPPORTED_LANGS, type Language } from '@/i18n/config';
import { t } from '@/i18n/utils';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({
    params: { lang },
  }));
}

const lang = Astro.params.lang as Language;
const title = t(lang, 'approach.meta.title');
const description = t(lang, 'approach.meta.description');

const pipeline = t(lang, 'approach.pipeline');
const analogy = t(lang, 'approach.analogy');
---

<BaseLayout title={title} description={description} lang={lang}>
  <Header lang={lang} />
  <main id="main" class="pt-32 pb-24">

    <!-- Hero -->
    <section class="mx-auto max-w-4xl px-6 mb-24">
      <p class="text-sm font-medium uppercase tracking-widest text-primary mb-4" data-animate>{t(lang, 'approach.label')}</p>
      <h1 class="font-heading text-4xl font-bold md:text-5xl lg:text-6xl mb-6" data-animate>
        {t(lang, 'approach.title')}
      </h1>
      <p class="text-lg text-text-secondary max-w-2xl" data-animate>
        {t(lang, 'approach.subtitle')}
      </p>
    </section>

    <!-- Pipeline -->
    <section class="mx-auto max-w-4xl px-6 mb-32">
      <h2 class="font-heading text-2xl font-bold mb-12" data-animate>{pipeline.title}</h2>

      <!-- Progress Line -->
      <div class="relative" data-animate>
        <!-- Horizontal line (desktop) -->
        <div class="hidden md:block absolute top-6 left-0 right-0 h-0.5 bg-border"></div>
        <div class="hidden md:block absolute top-6 left-0 h-0.5 bg-primary transition-all duration-1000" id="pipeline-progress" style="width: 0%"></div>

        <!-- Vertical line (mobile) -->
        <div class="md:hidden absolute top-0 bottom-0 left-6 w-0.5 bg-border"></div>
        <div class="md:hidden absolute top-0 left-6 w-0.5 bg-primary transition-all duration-1000" id="pipeline-progress-mobile" style="height: 0%"></div>

        <!-- Steps -->
        <div class="grid grid-cols-1 md:grid-cols-5 gap-8 md:gap-4 relative">
          {pipeline.steps.map((step: {icon: string; name: string; desc: string}, i: number) => (
            <div class="pipeline-step flex md:flex-col items-start md:items-center text-left md:text-center pl-14 md:pl-0" data-step={i}>
              <div class="absolute left-3 md:static w-7 h-7 md:w-12 md:h-12 rounded-full bg-surface border-2 border-border flex items-center justify-center text-sm md:text-lg mb-0 md:mb-4 transition-all duration-300 z-10 pipeline-icon">
                {step.icon}
              </div>
              <div>
                <p class="text-sm font-semibold text-text mb-1">{step.name}</p>
                <p class="text-xs text-text-muted">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Codex Standards -->
    <section class="mx-auto max-w-4xl px-6 mb-32">
      <h2 class="font-heading text-2xl font-bold mb-4" data-animate>{t(lang, 'approach.codex.title')}</h2>
      <p class="text-text-secondary mb-10" data-animate>{t(lang, 'approach.codex.subtitle')}</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" data-animate>
        {[
          { icon: '📖', key: 'read' },
          { icon: '🔍', key: 'verify' },
          { icon: '🎯', key: 'one' },
          { icon: '✓', key: 'check' },
        ].map((rule) => (
          <div class="group rounded-xl border border-border bg-surface p-6 transition-all hover:border-primary/40 hover:bg-elevated">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xl">{rule.icon}</span>
              <h3 class="font-heading text-sm font-bold uppercase tracking-wider text-primary">
                {t(lang, `approach.codex.rules.${rule.key}.name` as any)}
              </h3>
            </div>
            <p class="text-sm text-text-secondary">
              {t(lang, `approach.codex.rules.${rule.key}.desc` as any)}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- Analogy -->
    <section class="mx-auto max-w-4xl px-6 mb-24">
      <h2 class="font-heading text-2xl font-bold mb-10" data-animate>{analogy.title}</h2>

      <div class="space-y-6" data-animate>
        {analogy.stages.map((stage: {era: string; icon: string; title: string; dev: string; desc: string}, i: number) => (
          <div class={`relative rounded-xl border p-6 transition-all ${i === 2 ? 'border-primary/60 bg-primary/5' : 'border-border bg-surface'}`}>
            <div class="flex items-start gap-4">
              <div class={`flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-xl ${i === 2 ? 'bg-primary/15' : 'bg-elevated'}`}>
                {stage.icon}
              </div>
              <div class="flex-1">
                <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 mb-2">
                  <span class="text-xs font-mono text-text-muted uppercase tracking-wider">{stage.era}</span>
                  <span class="hidden sm:block text-text-muted">·</span>
                  <h3 class="font-heading font-bold text-text">{stage.title}</h3>
                </div>
                <p class="text-sm text-text-secondary mb-2">{stage.dev}</p>
                <p class="text-xs text-text-muted italic">{stage.desc}</p>
              </div>
            </div>
            {i === 2 && (
              <div class="absolute -top-3 right-4 rounded-full bg-primary px-3 py-0.5 text-xs font-semibold text-white">
                {t(lang, 'approach.analogy.current')}
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-4xl px-6 text-center" data-animate>
      <p class="text-lg text-text-secondary mb-6">{t(lang, 'approach.cta')}</p>
      <a href={`/${lang}/#contact`} class="inline-flex items-center gap-2 rounded-full bg-primary px-8 py-3 font-medium text-white transition-all hover:bg-primary-light hover:shadow-lg hover:shadow-primary/20">
        {t(lang, 'contact.telegram')}
      </a>
    </section>

  </main>
  <Footer lang={lang} />

  <script>
    // Make all data-animate elements visible with fade-in
    const animateEls = document.querySelectorAll('[data-animate]');
    const fadeObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
          fadeObserver.unobserve(el);
        }
      });
    }, { threshold: 0.1 });

    animateEls.forEach((el) => {
      const htmlEl = el as HTMLElement;
      htmlEl.style.opacity = '0';
      htmlEl.style.transform = 'translateY(20px)';
      fadeObserver.observe(el);
    });

    // Pipeline progress animation
    const pipelineObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const progress = document.getElementById('pipeline-progress');
          const progressMobile = document.getElementById('pipeline-progress-mobile');
          if (progress) progress.style.width = '100%';
          if (progressMobile) progressMobile.style.height = '100%';

          const steps = document.querySelectorAll('.pipeline-step');
          steps.forEach((step, i) => {
            setTimeout(() => {
              const icon = step.querySelector('.pipeline-icon');
              if (icon) {
                icon.classList.remove('border-border', 'bg-surface');
                icon.classList.add('border-primary', 'bg-primary/10', 'text-primary');
              }
            }, i * 200);
          });

          pipelineObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    const pipelineSection = document.getElementById('pipeline-progress')?.closest('section');
    if (pipelineSection) pipelineObserver.observe(pipelineSection);
  </script>
</BaseLayout>
