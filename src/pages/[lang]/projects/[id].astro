---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ProjectGallery from '@/components/ProjectGallery.astro';
import TechBadge from '@/components/TechBadge.astro';
import Icons from '@/components/Icons.astro';
import { SUPPORTED_LANGS, type Language } from '@/i18n/config';
import { PROJECTS } from '@/data/projects';
import { t } from '@/i18n/utils';

export function getStaticPaths() {
  return SUPPORTED_LANGS.flatMap((lang) =>
    PROJECTS.map((project) => ({
      params: { lang, id: project.id },
      props: { project },
    }))
  );
}

const lang = Astro.params.lang as Language;
const { project } = Astro.props;

const currentIndex = PROJECTS.findIndex((p) => p.id === project.id);
const prevProject = currentIndex > 0 ? PROJECTS[currentIndex - 1] : PROJECTS[PROJECTS.length - 1];
const nextProject = currentIndex < PROJECTS.length - 1 ? PROJECTS[currentIndex + 1] : PROJECTS[0];

const title = `${project.title} — Temrjan`;
const description = project.descriptions[lang];
const paragraphs = project.longDescription[lang].split('\n\n');

// Explicit bright glow colors for the ambient effect
const glowColorsMap: Record<string, string> = {
  'oltinpay': 'rgba(245, 197, 24, 0.25)', // Gold
  'znai-cloud': 'rgba(56, 189, 248, 0.15)', // Bright Blue
  'askbiotact': 'rgba(139, 92, 246, 0.15)', // Purple
  'biotact': 'rgba(227, 30, 36, 0.2)', // Red
  'biotact-mail': 'rgba(156, 163, 175, 0.15)' // Light Gray
};
const ambientGlow = glowColorsMap[project.id] || 'rgba(227, 30, 36, 0.15)';
---

<BaseLayout title={title} description={description} lang={lang}>
  <Header lang={lang} />

  <main class="relative overflow-hidden px-6 pb-24 pt-32">
    <!-- Ambient Glow Header Effect -->
    <div 
      class="absolute top-[-5%] left-1/2 -translate-x-1/2 w-full max-w-4xl h-[400px] -z-10 blur-[100px] pointer-events-none rounded-full"
      style={`background: ${ambientGlow};`}
    ></div>

    <div class="mx-auto max-w-4xl relative z-10">
      <!-- Back + Live -->
      <div class="mb-10 flex items-center justify-between">
        <a
          href={`/${lang}/#projects`}
          class="group flex items-center gap-2 font-mono text-sm text-text-muted transition-colors hover:text-text"
        >
          <span class="transition-transform group-hover:-translate-x-1">&larr;</span>
          {t(lang, 'projectPage.back')}
        </a>
        {project.url && (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 rounded-full border border-border px-4 py-1.5 font-mono text-xs text-text-muted transition-colors hover:border-primary/40 hover:text-text"
          >
            {t(lang, 'projectPage.live')}
            <Icons name="external-link" size={14} />
          </a>
        )}
      </div>

      <!-- Category -->
      <div class="mb-4 flex items-center gap-4">
        <span class="font-mono text-xs uppercase tracking-widest text-text-muted">
          {project.category[lang]}
        </span>
        <div class="h-px flex-1 bg-border" />
      </div>

      <!-- Title -->
      <h1 class="font-heading text-4xl font-bold text-text md:text-6xl">
        {project.title}
      </h1>
      <div class="mt-5 h-1 w-16 bg-primary rounded-full" />

      <!-- Tagline -->
      <p class="mt-6 text-xl text-text-secondary leading-relaxed max-w-3xl">
        {project.descriptions[lang]}
      </p>

      <!-- Meta row -->
      <div class="mt-14 grid grid-cols-3 gap-6 border-y border-border py-8">
        <div>
          <div class="font-mono text-xs uppercase tracking-widest text-text-muted">
            {t(lang, 'projectPage.role')}
          </div>
          <div class="mt-2 text-sm font-semibold text-text">
            {t(lang, 'projectPage.fullStack')}
          </div>
        </div>
        <div>
          <div class="font-mono text-xs uppercase tracking-widest text-text-muted">
            {t(lang, 'projectPage.period')}
          </div>
          <div class="mt-2 text-sm font-semibold text-text">
            {t(lang, 'projectPage.periodValue')}
          </div>
        </div>
        <div>
          <div class="font-mono text-xs uppercase tracking-widest text-text-muted">
            {t(lang, 'projectPage.status')}
          </div>
          <div class="mt-2 text-sm font-semibold text-text">
            {t(lang, 'projectPage.production')}
          </div>
        </div>
      </div>

      <!-- Long description -->
      <div class="mt-12 space-y-6">
        {paragraphs.map((p) => (
          <p class="text-text-secondary leading-relaxed text-lg">{p}</p>
        ))}
      </div>

      <!-- Strengths -->
      <div class="mt-16">
        <div class="mb-8 flex items-center gap-4">
          <span class="font-mono text-sm uppercase tracking-widest text-text-muted">
            {t(lang, 'projectPage.strengths')}
          </span>
          <div class="h-px flex-1 bg-border" />
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {project.strengths[lang].map((s) => (
            <div class="flex gap-4 rounded-xl border border-border/50 bg-elevated/50 px-5 py-4 transition-colors hover:border-primary/30">
              <span class="mt-1 shrink-0 text-primary">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <span class="text-text-secondary leading-relaxed">{s}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Stack -->
      <div class="mt-16">
        <div class="mb-8 flex items-center gap-4">
          <span class="font-mono text-sm uppercase tracking-widest text-text-muted">
            {t(lang, 'projectPage.stack')}
          </span>
          <div class="h-px flex-1 bg-border" />
        </div>
        <div class="flex flex-wrap gap-3">
          {project.tech.map((techName) => (
            <TechBadge name={techName} />
          ))}
        </div>
      </div>

      <!-- Gallery -->
      {project.images.length > 0 && (
        <div class="mt-16">
          <div class="mb-8 flex items-center gap-4">
            <span class="font-mono text-sm uppercase tracking-widest text-text-muted">
              {t(lang, 'projectPage.gallery')}
            </span>
            <div class="h-px flex-1 bg-border" />
          </div>
          <ProjectGallery images={project.images} title={project.title} />
        </div>
      )}

      <!-- Prev / Next navigation -->
      <div class="mt-24 grid grid-cols-2 gap-6 border-t border-border pt-12">
        <a
          href={`/${lang}/projects/${prevProject.id}`}
          class="group flex flex-col items-start gap-2 transition-colors"
        >
          <span class="font-mono text-xs uppercase tracking-widest text-text-muted transition-transform group-hover:-translate-x-1">
            &larr; Prev Project
          </span>
          <span class="font-heading text-xl font-bold text-text group-hover:text-primary">
            {prevProject.title}
          </span>
        </a>
        <a
          href={`/${lang}/projects/${nextProject.id}`}
          class="group flex flex-col items-end gap-2 text-right transition-colors"
        >
          <span class="font-mono text-xs uppercase tracking-widest text-text-muted transition-transform group-hover:translate-x-1">
            Next Project &rarr;
          </span>
          <span class="font-heading text-xl font-bold text-text group-hover:text-primary">
            {nextProject.title}
          </span>
        </a>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
